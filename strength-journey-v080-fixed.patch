diff --git a/src/workoutFlow.css b/src/workoutFlow.css
new file mode 100644
index 0000000..6666666
--- /dev/null
+++ b/src/workoutFlow.css
@@ -0,0 +1,106 @@
+.workoutModeCard { margin-bottom: 14px; }
+
+.workoutModeOptions {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 10px;
+}
+
+.workoutModeButton {
+  min-height: 76px;
+  border: 1px solid rgba(148,163,184,.22);
+  border-radius: 18px;
+  background: rgba(13,19,32,.72);
+  color: var(--text);
+  padding: 12px;
+  text-align: left;
+  display: grid;
+  gap: 4px;
+}
+
+.workoutModeButton strong { font-size: 15px; }
+.workoutModeButton span { color: var(--muted); font-size: 12px; }
+
+.workoutModeButton.active {
+  border-color: rgba(96,165,250,.75);
+  background: rgba(35,49,71,.92);
+  box-shadow: inset 0 0 0 1px rgba(96,165,250,.18);
+}
+
+.workoutProgressCard {
+  position: sticky;
+  top: 8px;
+  z-index: 8;
+  margin: 14px 0 18px;
+  padding: 13px 15px;
+  border: 1px solid rgba(148,163,184,.18);
+  border-radius: 18px;
+  background: rgba(9,14,24,.9);
+  backdrop-filter: blur(18px);
+}
+
+.workoutProgressHeading {
+  display: flex;
+  justify-content: space-between;
+  gap: 10px;
+  margin-bottom: 9px;
+  font-size: 12px;
+}
+
+.workoutProgressHeading span { color: var(--green); font-weight: 850; }
+
+.workoutProgressTrack {
+  height: 8px;
+  border-radius: 999px;
+  overflow: hidden;
+  background: rgba(148,163,184,.18);
+}
+
+.workoutProgressFill {
+  height: 100%;
+  border-radius: inherit;
+  background: linear-gradient(90deg, var(--green), var(--blue));
+  transition: width .28s ease;
+}
+
+.workoutExerciseCard {
+  scroll-margin-top: 86px;
+  transition: background .24s ease, border-color .24s ease, transform .18s ease;
+}
+
+.workoutExerciseCard.activeExercise {
+  border-color: rgba(96,165,250,.6);
+  box-shadow: 0 18px 48px rgba(0,0,0,.25), 0 0 0 1px rgba(96,165,250,.12);
+}
+
+.workoutExerciseCard.completedExercise {
+  border-color: rgba(52,211,153,.58);
+  background: linear-gradient(135deg, rgba(18,50,36,.92), rgba(15,34,31,.88));
+}
+
+.completedExercise .collapseIcon {
+  color: #06130b;
+  background: var(--green);
+}
+
+.completedExercise h3,
+.completedExercise .collapsedSummary { color: #d1fae5; }
+
+.optionalPill {
+  display: inline-flex;
+  width: fit-content;
+  margin: 2px 0 5px;
+  padding: 4px 7px;
+  border-radius: 999px;
+  color: #bfdbfe;
+  background: rgba(96,165,250,.12);
+  border: 1px solid rgba(96,165,250,.28);
+  font-size: 10px;
+  font-weight: 850;
+  text-transform: uppercase;
+  letter-spacing: .05em;
+}
+
+@media (max-width: 420px) {
+  .workoutModeOptions { grid-template-columns: 1fr; }
+}
